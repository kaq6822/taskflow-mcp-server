# ----- Runtime mode --------------------------------------------------------
# `dev` — CORS permissive to the local Vite origins, frontend served by Vite.
# `production` — CORS locked down to TASKFLOW_CORS_ORIGINS; backend serves
#                 the built SPA from TASKFLOW_FRONTEND_DIST_DIR.
TASKFLOW_ENV=dev

# ----- Storage -------------------------------------------------------------
TASKFLOW_DB_URL=sqlite+aiosqlite:///./taskflow.db
TASKFLOW_STORAGE_DIR=./storage
TASKFLOW_STEP_CWD=./storage/runtime

# ----- Network binding -----------------------------------------------------
# Use 0.0.0.0 to accept remote connections; `localhost` to restrict to
# loopback only. Ports can be overridden freely.
TASKFLOW_API_HOST=0.0.0.0
TASKFLOW_API_PORT=8000
TASKFLOW_MCP_HOST=0.0.0.0
TASKFLOW_MCP_PORT=7391
TASKFLOW_FRONTEND_HOST=localhost
TASKFLOW_FRONTEND_PORT=5173

# Host clients should use to reach the API when they are NOT served by Vite
# proxy (Vite config uses this to build its proxy target).
TASKFLOW_API_HOST_PUBLIC=localhost

# ----- CORS ----------------------------------------------------------------
# Comma-separated list of allowed origins for /api. Empty means "no browser
# can call the API cross-origin" (same-origin proxy still works).
# Dev default:
TASKFLOW_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
# LAN example (replace with your own):
# TASKFLOW_CORS_ORIGINS=http://192.168.1.10:5173
# Production example:
# TASKFLOW_CORS_ORIGINS=https://taskflow.example.com

# ----- MCP -----------------------------------------------------------------
TASKFLOW_MCP_MAX_SYNC_SEC=600

# ----- Production --------------------------------------------------------
# Set after `make build`. Relative to the backend/ working directory.
# TASKFLOW_FRONTEND_DIST_DIR=../frontend/dist
